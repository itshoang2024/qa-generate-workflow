APP_ENV=local
API_PREFIX=/api/v1
AI_PROVIDER=openai 
NOTION_PROVIDER=mock
REPOSITORY_PROVIDER=supabase

# Optional real-provider credentials. Leave blank for mock-first local demo.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
NOTION_TOKEN=
NOTION_API_BASE_URL=https://api.notion.com/v1
NOTION_VERSION=2022-06-28
NOTION_EPIC_DATABASE_ID=
NOTION_STORY_DATABASE_ID=
NOTION_TASK_DATABASE_ID=
NOTION_TEST_CASE_DATABASE_ID=
NOTION_RETRY_COUNT=3
NOTION_RETRY_BACKOFF_SECONDS=1
NOTION_TIMEOUT_SECONDS=20

# Use Supabase Cloud by setting REPOSITORY_PROVIDER=supabase and filling these.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Leave blank to use the canonical repo data sample.
SNAKE_GDD_PATH=

UPLOAD_DIR=
MAX_UPLOAD_BYTES=10485760
